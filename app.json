{
  "expo": {
    "name": "AsaanCar",
    "slug": "asaancar-app",
    "version": "1.0.17",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7e246c"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.asaancar.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#7e246c"
      },
      "package": "com.asaancar.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES"
      ],
      "versionCode": 76
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "googleStaticMapsApiKey": "AIzaSyAl7gcr1SOMOmVcINkah0IjMVTqXaA8zw4",
      "googleMapsApiKey": "AIzaSyAl7gcr1SOMOmVcINkah0IjMVTqXaA8zw4",
      "forceUpdate": {
        "enabled": true,
        "message": "A newer version of AsaanCar is available with exciting new features and improvements. Please update the app to continue.",
        "storeUrl": "https://play.google.com/store/apps/details?id=com.asaancar.app",
        "endpoint": "/config"
      },
      "eas": {
        "projectId": "66901416-8014-459b-b2dd-43be0066b4c0"
      }
    }
  }
}
